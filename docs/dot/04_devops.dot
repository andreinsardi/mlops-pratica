digraph G {
    rankdir=LR;
    bgcolor="white";
    node [shape=box, style="filled,rounded", fontname="Helvetica", fontsize=14,
          fontcolor="white", margin="0.25,0.15", penwidth=0];
    edge [color="#595959", penwidth=2, arrowsize=1.0];
    splines=spline;
    nodesep=0.6; ranksep=1.0;
    F [label="feature/*", fillcolor="#5A8F4B", shape=box, fontcolor="white"];
    D [label="develop", fillcolor="#ED7D31", shape=box, fontcolor="white"];
    R [label="release/*", fillcolor="#595959", shape=box, fontcolor="white"];
    MA [label="main", fillcolor="#1F4E79", shape=box, fontcolor="white"];
    T [label="tag v*", fillcolor="#1F4E79", shape=box, fontcolor="white"];
    CI1 [label="CI feature\nruff + pytest", fillcolor="#5A8F4B", shape=box, fontcolor="white"];
    CI2 [label="CI release\ndocker build", fillcolor="#595959", shape=box, fontcolor="white"];
    CD1 [label="CD staging", fillcolor="#1F4E79", shape=box, fontcolor="white"];
    CD2 [label="CD producao", fillcolor="#ED7D31", shape=box, fontcolor="white"];
    F -> D;
    D -> R;
    R -> MA;
    MA -> T;
    F -> CI1 [style="dashed"];
    R -> CI2 [style="dashed"];
    MA -> CD1 [style="dashed"];
    T -> CD2 [style="dashed"];
}