# =============================================================================
# .env.example - copie para .env e ajuste se desejar
# Comando: cp .env.example .env
# =============================================================================

# Airflow Fernet Key (gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
AIRFLOW_FERNET_KEY=oQyDfPbjQQjFC2DqzGgxKnQ-J6cMTcL_aaCw4FMfQGY=

# Airflow Admin (criado pelo airflow-init)
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# MinIO (S3-compatible)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Postgres app (pgvector)
PG_APP_USER=app
PG_APP_PASSWORD=app
PG_APP_DB=app

# Ingestão HackerNews
HN_TOP_N=100
HN_API_BASE=https://hacker-news.firebaseio.com/v0

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_PREDITIVO=hn_classifier
MLFLOW_EXPERIMENT_EMBEDDINGS=hn_embeddings

# Modelos
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Treino preditivo
# Mínimo de exemplos para acionar o treino. Default 20 (didático).
# Suba este valor em produção (recomendado: 1000+).
MIN_TRAIN_SAMPLES=20
