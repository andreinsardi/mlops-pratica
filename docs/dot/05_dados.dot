digraph G {
    rankdir=LR;
    bgcolor="white";
    node [shape=box, style="filled,rounded", fontname="Helvetica", fontsize=14,
          fontcolor="white", margin="0.25,0.15", penwidth=0];
    edge [color="#595959", penwidth=2, arrowsize=1.0];
    splines=spline;
    nodesep=0.6; ranksep=1.0;
    API [label="HN API\nfirebaseio", fillcolor="#5A8F4B", shape=box, fontcolor="white"];
    RAW [label="raw parquet\nMinIO\ndt=YYYY-MM-DD/hr=HH", fillcolor="#1F4E79", shape=box, fontcolor="white"];
    CUR [label="curated\ndedup por id", fillcolor="#1F4E79", shape=box, fontcolor="white"];
    FT [label="features tabular", fillcolor="#ED7D31", shape=box, fontcolor="white"];
    FX [label="features text", fillcolor="#ED7D31", shape=box, fontcolor="white"];
    PG [label="Postgres + pgvector\nairflow / mlflow / app", fillcolor="#ED7D31", shape=cylinder, fontcolor="white"];
    API -> RAW;
    RAW -> CUR;
    CUR -> FT;
    CUR -> FX;
    FT -> PG;
    FX -> PG;
}